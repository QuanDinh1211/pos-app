// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

/**
 * ===================== ENUM =====================
 */

enum CommonStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum InventoryLogType {
  IMPORT
  EXPORT
  ADJUST
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ShiftScheduleStatus {
  ASSIGNED
  CONFIRMED
  ABSENT
  CANCELED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
}

enum VoucherDiscountType {
  PERCENT
  FIXED
}

enum AttendanceLogType {
  CHECK_IN
  CHECK_OUT
  BREAK_START
  BREAK_END
}

enum CashTransactionType {
  IN
  OUT
}

enum CashTransactionCategory {
  OPENING
  ADD_CASH
  BUY_ICE
  BUY_SUPPLIES
  SALARY_ADVANCE
  REFUND
  OTHER
  EXPENSE
}

enum ExpenseType {
  ELECTRIC
  WATER
  SALARY
  RENT
  MATERIAL
  MARKETING
  OTHER
}

/**
 * ===================== STORE =====================
 */

model Store {
  id Int @id @default(autoincrement())

  name    String
  phone   String?
  address String?

  status CommonStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users       User[]
  orders      Order[]
  inventories Inventory[]
  shifts      Shift[]
  tables      Table[]

  cashTransactions CashTransaction[]

  shiftTemplates ShiftTemplate[]
  shiftSchedules ShiftSchedule[]

  inventoryImports InventoryImport[]
  inventoryExports InventoryExport[]
  inventoryAdjusts InventoryAdjust[]
  inventoryCheck   InventoryCheck[]

  expenses Expense[]

  @@index([status])
}

/**
 * ===================== ROLE =====================
 */

model Role {
  id Int @id @default(autoincrement())

  code String @unique
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id Int @id @default(autoincrement())

  code String @unique
  name String

  roles RolePermission[]
}

model RolePermission {
  id Int @id @default(autoincrement())

  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/**
 * ===================== USER =====================
 */

model User {
  id Int @id @default(autoincrement())

  storeId Int?
  roleId  Int?

  name     String
  username String  @unique
  email    String? @unique
  password String

  avatar String?
  phone  String?

  status UserStatus @default(ACTIVE)

  lastLogin DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id])
  role  Role?  @relation(fields: [roleId], references: [id])

  orders        Order[]
  shifts        Shift[]
  inventoryLogs InventoryLog[]

  shiftSchedules ShiftSchedule[]

  attendanceLogs ShiftAttendanceLog[]

  cashTransactions CashTransaction[]

  inventoryImports InventoryImport[]
  inventoryExports InventoryExport[]
  inventoryAdjusts InventoryAdjust[]
  InventoryCheck   InventoryCheck[]

  expenses Expense[]

  shiftSwapFrom ShiftSwap[] @relation("ShiftSwapFrom")
  shiftSwapTo   ShiftSwap[] @relation("ShiftSwapTo")

  @@index([storeId])
  @@index([roleId])
  @@index([status])
}

/**
 * ===================== CATEGORY =====================
 */

model Category {
  id Int @id @default(autoincrement())

  name  String
  image String?

  sortOrder Int @default(0)

  status CommonStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]

  @@index([status])
}

/**
 * ===================== PRODUCT =====================
 */

model Product {
  id Int @id @default(autoincrement())

  categoryId Int?

  name String
  code String @unique
  slug String @unique

  image       String?
  description String?

  basePrice Int @default(0)
  costPrice Int @default(0)

  isCombo Boolean @default(false)

  status CommonStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  category Category? @relation(fields: [categoryId], references: [id])

  sizes      ProductSize[]
  toppings   ProductTopping[]
  orderItems OrderItem[]
  recipes    Recipe[]

  @@index([categoryId])
  @@index([status])
}

/**
 * ===================== PRODUCT SIZE =====================
 */

model ProductSize {
  id Int @id @default(autoincrement())

  productId Int

  sizeName String
  price    Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

/**
 * ===================== TOPPING =====================
 */

model Topping {
  id Int @id @default(autoincrement())

  name  String
  image String?

  price Int @default(0)

  stock Int @default(0)

  status CommonStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  productToppings   ProductTopping[]
  orderItemToppings OrderItemTopping[]

  @@index([status])
}

/**
 * ===================== PRODUCT TOPPING =====================
 */

model ProductTopping {
  id Int @id @default(autoincrement())

  productId Int
  toppingId Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  topping Topping @relation(fields: [toppingId], references: [id], onDelete: Cascade)

  @@unique([productId, toppingId])
  @@index([productId])
  @@index([toppingId])
}

/**
 * ===================== CUSTOMER =====================
 */

model Customer {
  id Int @id @default(autoincrement())

  name  String?
  phone String? @unique
  email String?

  points     Int @default(0)
  totalSpent Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orders Order[]

  @@index([phone])
}

/**
 * ===================== TABLE =====================
 */

model Table {
  id Int @id @default(autoincrement())

  storeId Int?

  name   String
  status CommonStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  orders Order[]

  @@index([storeId])
}

/**
 * ===================== ORDER =====================
 */

model Order {
  id Int @id @default(autoincrement())

  storeId    Int?
  userId     Int?
  customerId Int?
  voucherId  Int?
  tableId    Int?
  shiftId    Int?

  orderCode String @unique

  subtotal       Int @default(0)
  discountAmount Int @default(0)
  taxAmount      Int @default(0)
  totalAmount    Int @default(0)

  paymentMethod PaymentMethod?

  paymentStatus PaymentStatus @default(PENDING)
  orderStatus   OrderStatus   @default(PENDING)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store?    @relation(fields: [storeId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  voucher  Voucher?  @relation(fields: [voucherId], references: [id])
  table    Table?    @relation(fields: [tableId], references: [id])

  shift Shift? @relation(fields: [shiftId], references: [id])

  items    OrderItem[]
  payments Payment[]

  @@index([storeId])
  @@index([userId])
  @@index([customerId])
  @@index([voucherId])
  @@index([tableId])
  @@index([shiftId])
  @@index([createdAt])
  @@index([orderStatus])
  @@index([paymentStatus])
}

/**
 * ===================== ORDER ITEM =====================
 */

model OrderItem {
  id Int @id @default(autoincrement())

  orderId   Int
  productId Int?

  productName String
  sizeName    String?

  quantity Int @default(1)

  price      Int @default(0)
  totalPrice Int @default(0)

  note String?

  createdAt DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  toppings OrderItemTopping[]

  @@index([orderId])
  @@index([productId])
}

/**
 * ===================== ORDER ITEM TOPPING =====================
 */

model OrderItemTopping {
  id Int @id @default(autoincrement())

  orderItemId Int
  toppingId   Int?

  toppingName String
  price       Int    @default(0)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  topping   Topping?  @relation(fields: [toppingId], references: [id])

  @@index([orderItemId])
  @@index([toppingId])
}

/**
 * ===================== PAYMENT =====================
 */

model Payment {
  id Int @id @default(autoincrement())

  orderId Int

  paymentMethod PaymentMethod?

  amount Int @default(0)

  transactionCode String?

  status PaymentStatus @default(PENDING)

  paidAt DateTime?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model Expense {
  id          Int @id @default(autoincrement())

  storeId     Int?
  userId      Int?

  type        ExpenseType

  title       String

  amount      Int @default(0)

  note        String?

  expenseDate DateTime

  createdAt   DateTime @default(now())

  store       Store? @relation(fields: [storeId], references: [id])

  user        User? @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([type])
  @@index([expenseDate])
}

/**
 * ===================== INVENTORY =====================
 */

model Inventory {
  id Int @id @default(autoincrement())

  storeId Int?

  name String
  unit String

  quantity    Float @default(0)
  minQuantity Float @default(0)

  costPrice Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  logs    InventoryLog[]
  recipes Recipe[]

  importItems    InventoryImportItem[]
  exportItems    InventoryExportItem[]
  adjustItems    InventoryAdjustItem[]
  checkItemItems InventoryCheckItem[]

  @@index([storeId])
}

/**
 * ===================== INVENTORY LOG =====================
 */

model InventoryLog {
  id Int @id @default(autoincrement())

  inventoryId Int

  type InventoryLogType

  quantity Float @default(0)

  note String?

  createdBy Int?

  createdAt DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [createdBy], references: [id])

  @@index([inventoryId])
  @@index([createdBy])
  @@index([createdAt])
}

model InventoryImport {
  id        Int      @id @default(autoincrement())
  storeId   Int?
  userId    Int?
  code      String   @unique
  note      String?
  totalCost Int      @default(0)
  status    String   @default("DONE") // DONE | CANCELED
  createdAt DateTime @default(now())

  store Store?                @relation(fields: [storeId], references: [id])
  user  User?                 @relation(fields: [userId], references: [id])
  items InventoryImportItem[]

  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([storeId, createdAt]) // Index kép rất hữu ích
}

model InventoryImportItem {
  id          Int   @id @default(autoincrement())
  importId    Int
  inventoryId Int
  quantity    Float
  unitPrice   Int   @default(0) // Giá nhập mỗi đơn vị
  totalPrice  Int   @default(0) // = quantity * unitPrice

  import    InventoryImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  inventory Inventory       @relation(fields: [inventoryId], references: [id])

  @@index([importId])
  @@index([inventoryId])
}

model InventoryExport {
  id        Int      @id @default(autoincrement())
  storeId   Int?
  userId    Int?
  code      String   @unique
  note      String?
  totalCost Int      @default(0)
  status    String   @default("DONE") // DONE | CANCELED
  createdAt DateTime @default(now())

  store Store?                @relation(fields: [storeId], references: [id])
  user  User?                 @relation(fields: [userId], references: [id])
  items InventoryExportItem[]

  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([storeId, createdAt])
}

model InventoryExportItem {
  id          Int   @id @default(autoincrement())
  exportId    Int
  inventoryId Int
  quantity    Float
  unitCost    Int   @default(0) // Giá vốn lúc xuất (averageCost)
  totalCost   Int   @default(0) // = quantity * unitCost

  export    InventoryExport @relation(fields: [exportId], references: [id], onDelete: Cascade)
  inventory Inventory       @relation(fields: [inventoryId], references: [id])

  @@index([exportId])
  @@index([inventoryId])
}

model InventoryAdjust {
  id        Int      @id @default(autoincrement())
  storeId   Int?
  userId    Int?
  code      String   @unique
  note      String?
  status    String   @default("DONE") // DONE | CANCELED
  createdAt DateTime @default(now())

  store Store?                @relation(fields: [storeId], references: [id])
  user  User?                 @relation(fields: [userId], references: [id])
  items InventoryAdjustItem[]

  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([storeId, createdAt])
}

model InventoryAdjustItem {
  id             Int     @id @default(autoincrement())
  adjustId       Int
  inventoryId    Int
  systemQuantity Float   @default(0) // Số lượng theo hệ thống
  actualQuantity Float   @default(0) // Số lượng kiểm kê thực tế
  difference     Float   @default(0) // Chênh lệch
  note           String?

  adjust    InventoryAdjust @relation(fields: [adjustId], references: [id], onDelete: Cascade)
  inventory Inventory       @relation(fields: [inventoryId], references: [id])

  @@index([adjustId])
  @@index([inventoryId])
}

model InventoryCheck {
  id Int @id @default(autoincrement())

  storeId Int?
  userId  Int?

  code String @unique

  note String?

  status String @default("DONE") // DONE | CANCELED

  createdAt DateTime @default(now())

  items InventoryCheckItem[]

  store Store? @relation(fields: [storeId], references: [id])

  user User? @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
}

model InventoryCheckItem {
  id Int @id @default(autoincrement())

  checkId Int

  inventoryId Int

  systemQuantity Float @default(0)

  actualQuantity Float @default(0)

  difference Float @default(0)

  note String?

  check InventoryCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@index([checkId])
  @@index([inventoryId])
}

/**
 * ===================== RECIPE =====================
 */

model Recipe {
  id Int @id @default(autoincrement())

  productId   Int
  inventoryId Int

  quantity Float @default(0)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@unique([productId, inventoryId])
  @@index([productId])
  @@index([inventoryId])
}

/**
 * ===================== SHIFT =====================
 */

model ShiftTemplate {
  id Int @id @default(autoincrement())

  storeId Int?

  code String @unique
  name String

  startTime String
  endTime   String

  color String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  schedules ShiftSchedule[]

  @@index([storeId])
}

model ShiftSchedule {
  id Int @id @default(autoincrement())

  storeId         Int?
  userId          Int?
  shiftTemplateId Int?

  workDate DateTime

  note String?

  createdBy Int?

  status ShiftScheduleStatus @default(ASSIGNED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  user User? @relation(fields: [userId], references: [id])

  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id])

  attendances ShiftAttendanceLog[]
  shifts      Shift[]
  swaps       ShiftSwap[]

  @@unique([userId, workDate, shiftTemplateId])
  @@index([workDate])
  @@index([userId])
  @@index([storeId])
}

model ShiftAttendanceLog {
  id Int @id @default(autoincrement())

  shiftScheduleId Int

  userId Int?

  type AttendanceLogType

  createdAt DateTime @default(now())

  note String?

  shiftSchedule ShiftSchedule @relation(fields: [shiftScheduleId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id])

  @@index([shiftScheduleId])
  @@index([userId])
  @@index([createdAt])
}

model ShiftSwap {
  id Int @id @default(autoincrement())

  fromUserId Int
  toUserId   Int

  shiftScheduleId Int

  status String

  createdAt DateTime @default(now())

  fromUser User @relation("ShiftSwapFrom", fields: [fromUserId], references: [id])

  toUser User @relation("ShiftSwapTo", fields: [toUserId], references: [id])

  shiftSchedule ShiftSchedule @relation(fields: [shiftScheduleId], references: [id])

  cashTransactions CashTransaction[]

  @@index([fromUserId])
  @@index([toUserId])
  @@index([shiftScheduleId])
}

model Shift {
  id Int @id @default(autoincrement())

  storeId Int?
  userId  Int?

  shiftScheduleId Int?

  startCash Int @default(0)
  endCash   Int @default(0)

  expectedCash Int @default(0)
  actualCash   Int @default(0)

  differenceCash Int @default(0)

  startedAt DateTime?
  endedAt   DateTime?

  note String?

  status ShiftStatus @default(OPEN)

  createdAt DateTime @default(now())

  store Store? @relation(fields: [storeId], references: [id])

  user User? @relation(fields: [userId], references: [id])

  shiftSchedule ShiftSchedule? @relation(fields: [shiftScheduleId], references: [id])

  orders Order[]

  cashTransactions CashTransaction[]

  @@unique([shiftScheduleId])
  @@index([storeId])
  @@index([userId])
  @@index([status])
}

/**
 * ===================== VOUCHER =====================
 */

model Voucher {
  id Int @id @default(autoincrement())

  code String @unique

  discountType VoucherDiscountType

  discountValue Int @default(0)

  maxDiscount    Int?
  minOrderAmount Int  @default(0)

  expiredAt DateTime?

  quantity  Int @default(0)
  usedCount Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orders Order[]
}

/**
 * ===================== ACTIVITY LOG =====================
 */

model ActivityLog {
  id Int @id @default(autoincrement())

  userId Int?

  action   String
  entity   String
  entityId Int?

  oldData Json?
  newData Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
}

/**
 * ===================== SETTING =====================
 */

model Setting {
  id Int @id @default(autoincrement())

  key   String  @unique
  value String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * ===================== CASH =====================
 */

model CashTransaction {
  id Int @id @default(autoincrement())

  storeId Int?
  shiftId Int?

  userId Int?

  type CashTransactionType

  amount Int @default(0)

  category CashTransactionCategory
  reason   String?

  createdAt DateTime @default(now())

  store Store? @relation(fields: [storeId], references: [id])

  shift Shift? @relation(fields: [shiftId], references: [id])

  user        User?      @relation(fields: [userId], references: [id])
  shiftSwap   ShiftSwap? @relation(fields: [shiftSwapId], references: [id])
  shiftSwapId Int?

  @@index([storeId])
  @@index([shiftId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
